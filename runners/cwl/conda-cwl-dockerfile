FROM ghcr.io/geo-bon/bon-in-a-box-pipelines/runner-conda

# Install CURL, needed to download conda-pack environments from the specified URL
RUN set -ex; \
    apt-get update; \
    apt-get install -y --no-install-recommends curl; \
    apt-get clean all;

# Add conda-pack to the base environment
RUN mamba install -n base conda-pack

