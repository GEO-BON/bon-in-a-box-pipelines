      "description": "Select the bounding box for the study area.",
      "type": "bboxCRS",
      "example": null,
      "weight": 1
    },
    "rasterAnalysis.yml@5|high_aries_threshold": {
      "description": "ARIES values above this are considered high-occurrence for binary analyses. Between 0 and 1.\n",
      "label": "High ARIES value threshold",
      "type": "float",
      "example": 0.6,
      "weight": 2
    },
    "rasterAnalysis.yml@5|high_heat_threshold": {
      "description": "Normalised heatmap values above this are considered high-density for binary analyses. Between 0 and 1.\n",
      "label": "High heatmap value threshold",
      "type": "float",
      "example": 0.6,
      "weight": 3
    },
    "pipeline@7": {
      "label": "minimum year",
      "description": "Min year observations wanted",
      "type": "int",
      "example": 2010,
      "weight": 4
    },
    "pipeline@8": {
      "label": "maximum year",
      "description": "Max year observations wanted",
      "type": "int",
      "example": 2026,
      "weight": 3
    }
  },
  "outputs": {
    "rasterAnalysis.yml@5|residual_raster": {
      "description": "GeoTIFF of ARIES minus normalised heatmap per cell",
      "label": "Residual raster",
      "type": "image/tiff;application=geotiff",
      "weight": 0
    },
    "rasterAnalysis.yml@5|gap_raster": {
      "description": "GeoTIFF marking cells with high ARIES value but low heatmap density",
      "label": "Gap analysis raster",
      "type": "image/tiff;application=geotiff",
      "weight": 1
    },
    "rasterAnalysis.yml@5|plot_correlation": {
      "description": "Scatter and 2D density of ARIES vs heatmap values",
      "label": "Correlation plot",
      "type": "image/png",
      "weight": 2
    },
    "rasterAnalysis.yml@5|plot_residual": {
      "description": "Map showing where ARIES over- and underpredicts relative to heatmap",
      "label": "Residual map plot",
      "type": "image/png",
      "weight": 3
    },
    "rasterAnalysis.yml@5|plot_gap_analysis": {
      "description": "Three-panel map of ARIES raster, heatmap, and gap cells",
      "label": "Gap analysis map",
      "type": "image/png",
      "weight": 4
    },
    "rasterAnalysis.yml@5|plot_confusion": {
      "description": "Binary agreement between ARIES and heatmap with kappa score",
      "label": "Confusion matrix plot",
      "type": "image/png",
      "weight": 5
    },
    "rasterAnalysis.yml@5|plot_roc": {
      "description": "ROC/AUC treating heatmap as ground truth and ARIES as predictor",
      "label": "ROC curve plot",
      "type": "image/png",
      "weight": 6
    },
    "rasterAnalysis.yml@5|plot_hotspot": {
      "description": "Four-class map showing agreement and disagreement between hotspots",
      "label": "Hotspot overlap map",
      "type": "image/png",
      "weight": 7
    }
